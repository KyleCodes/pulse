{
  "name": "api",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t pulse-api:${TAG:-dev} apps/api",
        "cwd": "{workspaceRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./run-dev.sh",
        "cwd": "{projectRoot}"
      }
    }
  }
}
