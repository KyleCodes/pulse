{
  "uid": "pulse-ops",
  "title": "Pulse Ops",
  "tags": ["pulse"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "compose_service", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queue depth",
      "description": "Unprocessed events in events_queue. Should hover near 0; climbing = worker down or under-scaled (see runbook).",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*)::bigint AS depth FROM events_queue;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Oldest unprocessed event age (s)",
      "description": "now() - min(received_at) over the queue. The no-data-loss panel: during a worker outage this climbs; after recovery it returns to ~0.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT coalesce(extract(epoch FROM now() - min(received_at)), 0)::float AS oldest_age_seconds FROM events_queue;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Events processed per minute",
      "description": "Rows landing in lcp_samples by minute bucket — worker throughput.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT bucket_start AS time, count(*)::bigint AS processed FROM lcp_samples WHERE $__timeFilter(bucket_start) GROUP BY 1 ORDER BY 1;"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top pages by volume",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT site_id, page_url, event_count, p75_lcp_ms, last_seen FROM page_aggregates ORDER BY event_count DESC LIMIT 20;"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p75 LCP by site (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT bucket_start AS time, site_id AS metric, percentile_cont(0.75) WITHIN GROUP (ORDER BY lcp_ms)::float AS p75 FROM lcp_samples WHERE $__timeFilter(bucket_start) GROUP BY 1, 2 ORDER BY 1;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Service logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=~\"$service\"}"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
